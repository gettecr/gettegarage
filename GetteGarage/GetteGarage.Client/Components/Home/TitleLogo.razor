@using MudBlazor
@using GetteGarage.Client.Services
@inject AchievementService Achievements


<div class="logo-section cursor-pointer" @onclick="HandleLogoClick">
    
    <!--Top Text (Fades In) -->
    <MudText Typo="Typo.h1" Color="Color.Primary" Align="Align.Center" Class="title-text fade-in-slow">
        GETTE
    </MudText>

    <!-- The Logo (Slides in from Right) -->
    <div class="logo-container my-6">
        <!-- Adjust max-height to fit your specific logo size -->
        <img src="/images/GetteGarageLogo_simple.png" class="sliding-logo" alt="Gette Garage Logo" />
    </div>

    <!-- Bottom Text (Fades In) -->
    <MudText Typo="Typo.h1" Color="Color.Primary" Align="Align.Center" Class="title-text fade-in-slow">
        GARAGE
    </MudText>
    
    <!-- 4. Press Start (Blinks, delayed) -->
    @* <MudText Typo="Typo.h5" Class="mt-6 press-start-blink" Align="Align.Center" Color="Color.Secondary">
        PRESS START 
    </MudText> *@

</div>


<style>
    .logo-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        user-select: none;
        padding: 1rem;
        /* Reduce min-height for mobile so it doesn't push the menu too far down */
        min-height: 300px; 
        justify-content: center;
        width: 100%;
    }

    @@media (max-width: 600px) {
        .logo-section {
            min-height: 200px;
            padding-top: 2rem;
        }
        .fade-in-slow {
            font-size: 2.5rem !important; /* Scale down GETTE GARAGE text */
        }
        .sliding-logo {
            max-height: 100px; /* Smaller logo for mobile */
        }
    }

    /* TEXT ANIMATION: Start invisible, fade in */
    .fade-in-slow {
        opacity: 0;
        animation: textFadeIn 2s ease-out forwards;
        animation-delay: 0.5s; /* Wait for logo to start moving */
        line-height: 1.2;
        font-size: 4rem; /* Adjust based on preference */
    }

    /* LOGO ANIMATION: Start off-screen right, slide to center */
    .sliding-logo {
        max-height: 300px; /* Control logo size */
        width: auto;
        
        /* Start position (Off screen right) */
        transform: translateX(100vw) rotate(10deg); 
        opacity: 0;
        
        animation: logoSlideIn 1.2s cubic-bezier(0.17, 0.67, 0.23, 0.96) forwards;
    }

    .press-start-blink {
        opacity: 0; 
        animation: blink-hard 1s infinite;
        animation-delay: 2.5s;
    }

    /* --- KEYFRAMES --- */

    @@keyframes textFadeIn {
        0% { opacity: 0; transform: scale(0.9); }
        100% { opacity: 1; transform: scale(1); }
    }

    @@keyframes logoSlideIn {
        0% {
            transform: translateX(100vw) rotate(10deg);
            opacity: 0;
        }
        60% {
            /* Overshoot slightly for impact */
            transform: translateX(-20px) rotate(-5deg); 
            opacity: 1;
        }
        100% {
            transform: translateX(0) rotate(0deg);
            opacity: 1;
        }
    }

    @@keyframes blink { 0% { opacity: 1; } }


    @@keyframes blink-hard {
        0%   { opacity: 0; } 
        50%  { opacity: 1; } 
        100% { opacity: 0; } 
    }
    
    /* Mobile Adjustment */
    @@media (max-width: 600px) {
        .title-text { font-size: 2.5rem !important; }
        .sliding-logo { max-height: 100px; }
    }
</style>

@code {
    private int _clickCount = 0;

    private async Task HandleLogoClick()
    {
        _clickCount++;
        if (_clickCount == 5)
        {
            await Achievements.Unlock("garage_door", "Garage Opener", "You knocked on the door 5 times.");
            
            // Optional: Reset count so they don't spam it
            _clickCount = 0; 
        }
    }
}
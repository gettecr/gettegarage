
<div class="menu-row @(_isVisible ? "visible" : "")">
    <GameMenuButton Title="WORKSHOP" Subtitle="Projects & Work" Link="/workshop" Delay="0.6s" />
    <GameMenuButton Title="DEV_LOG" Subtitle="Read the Blog" Link="/blog" Delay="0.7s" />
    <GameMenuButton Title="ARCADE" Subtitle="Play Minigames" Link="/arcade" Delay="0.8s" />
    <GameMenuButton Title="GALLERY" Subtitle="Art & Assets" Link="/gallery" Delay="0.9s" />
    <GameMenuButton Title="CREDITS" Subtitle="About Me" Link="/about" Delay="1.0s" />
</div>

<style>
    .menu-row {
        display: flex;
        flex-direction: row;
        gap: 2rem;
        flex-wrap: wrap; 
        justify-content: center;
        width: 100%;
        max-width: 1200px;
        
        /* Start Hidden */
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.5s ease-out, transform 0.5s ease-out;
    }

    /* End State */
    .menu-row.visible {
        opacity: 1;
        transform: translateY(0);
    }
</style>

@code {
    private bool _isVisible = false;
    private const int _delay = 1000;
    private float _delay_in_seconds = _delay / 1000;


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Wait 0.5 seconds (Logo Slide + Text Fade duration)
            await Task.Delay(500);
            _isVisible = true;
            StateHasChanged();
        }
    }
}
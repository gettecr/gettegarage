@using MudBlazor
@using System.Security.Cryptography
@inject NavigationManager Nav
@rendermode InteractiveWebAssembly
@inject AchievementService Achievements

<MudDialog Class="terminal-dialog-frame">
    <DialogContent>
        <div class="terminal-window">
            <div class="d-flex justify-space-between mb-2">
                <MudText Typo="Typo.caption" Color="Color.Success" Style="font-family: monospace;">gettegarage@terminal:~$</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="Close" Color="Color.Error" />
            </div>
            
            <!-- Output History -->
            <div class="terminal-history mb-2 custom-scroll">
                @foreach (var line in History)
                {
                    <div class="@line.CssClass">@((MarkupString)line.Text)</div>
                }
            </div>

            <!-- Input Line -->
            <div class="d-flex align-center">
                <span class="mr-2 text-success">➜</span>
                <input @ref="inputElement" 
                       class="terminal-input" 
                       @bind="CurrentInput" 
                       @onkeyup="HandleKeyUp" 
                       placeholder="Type 'help'..." 
                       autofocus />
            </div>
        </div>
    </DialogContent>
</MudDialog>

<style>
    /* Force the MudDialog to look like a terminal */
    .terminal-dialog-frame {
        background: #1e1e1e !important;
        border: 1px solid #333 !important;
        max-width: 650px !important;
    }
    .terminal-window {
        height: 400px; color: #00ff00;
        font-family: 'Courier New', monospace; display: flex; flex-direction: column;
    }
    .terminal-history { flex-grow: 1; overflow-y: auto; font-size: 0.9rem; }
    .terminal-input {
        background: transparent; border: none; color: white; width: 100%; outline: none; font-family: inherit;
    }
    .text-success { color: #2ecc71; }
    .text-warning { color: #f1c40f; }
    .text-info    { color: #3498db; }
</style>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; }
    
    private string CurrentInput = "";
    private ElementReference inputElement;
    
    class TermLine { public string Text { get; set; } public string CssClass { get; set; } }
    private List<TermLine> History = new() {
        new TermLine { Text = "Welcome to GETTEGARAGEOS v1.0. Type <b>help</b> for commands.", CssClass = "text-info" }
    };

    private void Close() => MudDialog.Cancel();

    private async Task HandleKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(CurrentInput))
        {
            await ProcessCommand(CurrentInput.Trim().ToLower());
            CurrentInput = "";
        }
    }

    private async Task ProcessCommand(string cmd)
    {
        History.Add(new TermLine { Text = $"➜ {cmd}", CssClass = "text-success" });

        switch (cmd)
        {
            case "help":
                History.Add(new TermLine { Text = "Available commands:", CssClass = "text-warning" });
                History.Add(new TermLine { Text = "&nbsp; whoami  - About me", CssClass = "" });
                History.Add(new TermLine { Text = "&nbsp; ls      - List pages", CssClass = "" });
                History.Add(new TermLine { Text = "&nbsp; go [pg] - Navigate", CssClass = "" });
                History.Add(new TermLine { Text = "&nbsp; hello   - Say hi", CssClass = "" }); // Added help text
                History.Add(new TermLine { Text = "&nbsp; clear   - Clear screen", CssClass = "" });
                break;

            case "whoami":
                History.Add(new TermLine { Text = "I am an indie game dev and artist who does data science for money.", CssClass = "" });
                break;

            // NEW ACHIEVEMENT 
            case "hello":
            case "hi":
                History.Add(new TermLine { Text = "Hello there! Beep boop.", CssClass = "" });
                
                await Achievements.Unlock("terminal_hello", "Hello World", "You said hi to the machine.");
                break;

            case "ls":
                History.Add(new TermLine { Text = "files/pages:", CssClass = "text-warning" });
                History.Add(new TermLine { Text = "home  credits  workshop  arcade  blog  community  big-larry  tidebreaker", CssClass = "" });
                break;
                
            case "clear":
                History.Clear();
                break;

            case "go home": Nav.NavigateTo("/"); Close(); break;
            case "go credits": Nav.NavigateTo("/about"); Close(); break;
            case "go workshop": Nav.NavigateTo("/workshop"); Close(); break;
            case "go arcade": Nav.NavigateTo("/arcade"); Close(); break;
            case "go blog": Nav.NavigateTo("/blog"); Close(); break;
            case "go community":Nav.NavigateTo(uri: "/community"); Close(); break;
            case "go big-larry":Nav.NavigateTo(uri: "play/big-larrys-beach-baseball"); Close(); break;
            case "go tidebreaker":Nav.NavigateTo(uri: "play/tidebreaker"); Close(); break;

            default:
                if (cmd.StartsWith("go "))
                    History.Add(new TermLine { Text = $"Error: Page '{cmd.Substring(3)}' not found.", CssClass = "text-warning" });
                else
                    History.Add(new TermLine { Text = $"Command not found: {cmd}", CssClass = "text-warning" });
                break;
        }
        
    }
}
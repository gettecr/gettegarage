@using MudBlazor
@inject NavigationManager Nav
@rendermode InteractiveWebAssembly

<MudAppBar Elevation="0" Fixed="true" 
                   Style="background: rgba(5, 5, 16, 0.9); backdrop-filter: blur(8px); border-bottom: 1px solid #333; height: 64px;">


    <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" 
                    Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" 
                    Class="d-flex d-md-none" />

    <MudIconButton Icon="@Icons.Material.Filled.Home" Color="Color.Primary" 
                    Edge="Edge.Start" Href="/" Class="d-none d-md-flex" />
    
    <MudText Typo="Typo.button" Class="ml-4 d-none d-sm-flex" Color="Color.Inherit" 
                Style="font-family: 'Press Start 2P'; font-size: 0.8rem;">
        GETTEGARAGE // @GetSectionTitle()
    </MudText>

    <MudSpacer />

    <!-- Desktop Links -->
    <div class="d-none d-md-flex gap-4">
        <MudButton Href="/workshop" Color="Color.Inherit" Variant="Variant.Text">WORKSHOP</MudButton>
        <MudButton Href="/blog" Color="Color.Inherit" Variant="Variant.Text">DEV_LOG</MudButton>
        <MudButton Href="/arcade" Color="Color.Inherit" Variant="Variant.Text">ARCADE</MudButton>
        <MudButton Href="/about" Color="Color.Inherit" Variant="Variant.Text">CREDITS</MudButton>
        <MudButton Href="/community" Color="Color.Inherit" Variant="Variant.Text">COMMUNITY</MudButton>
        <GetteGarage.Client.Components.Shared.LiveSignalWidget />
    </div>
            

</MudAppBar>

<MudDrawer @bind-Open="_drawerOpen" Elevation="1" Anchor="Anchor.Left" 
            Variant="@DrawerVariant.Temporary" 
            Fixed="true"
            Style="background: #050510; border-right: 1px solid #333;"
            Width="100%">
    
    <MudDrawerHeader Class="pa-4 d-flex justify-center align-center" Style="border-bottom: 1px solid #333;">
        <MudText Typo="Typo.h6" Color="Color.Primary" Style="font-family: 'Press Start 2P'; font-size: 1.5rem;">
            MAIN MENU
        </MudText>
    </MudDrawerHeader>
    
    <MudNavMenu Class="pa-2">
        <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home" Match="NavLinkMatch.All" Class="drawer-nav-link">HOME</MudNavLink>
        <MudDivider Class="my-2" />
        <MudNavLink Href="/workshop" Icon="@Icons.Material.Filled.Work" Class="drawer-nav-link">WORKSHOP</MudNavLink>
        <MudNavLink Href="/blog" Icon="@Icons.Material.Filled.Book" Class="drawer-nav-link">DEV_LOG</MudNavLink>
        <MudNavLink Href="/arcade" Icon="@Icons.Material.Filled.Gamepad" Class="drawer-nav-link">ARCADE</MudNavLink>
        <MudNavLink Href="/about" Icon="@Icons.Material.Filled.Person" Class="drawer-nav-link">CREDITS</MudNavLink>
        <MudNavLink Href="/community" Icon="@Icons.Material.Filled.Public" Class="drawer-nav-link">COMMUNITY</MudNavLink>
    </MudNavMenu>
</MudDrawer>

<style>

    .mud-drawer-temporary {
        z-index: 3000 !important;
        position: fixed !important;
    }

    /* 2. Ensure the dark overlay (that dims the page) is also on top */
    .mud-drawer-overlay {
        z-index: 2999 !important;
        position: fixed !important;
    }

    .drawer-nav-link {
        font-family: 'Press Start 2P';
        font-size: 1.1rem;
        padding-top: 0.9rem !important;
        padding-bottom: 0.9rem !important;
    }

    .drawer-nav-link .mud-nav-link {
        display: flex !important;
        justify-content: center !important;
        align-items: center !important;
        
        /* Remove the default padding that pins things to the left edge */
        padding-left: 0 !important;
        padding-right: 0 !important;
        height: 60px !important; 
    }

    .drawer-nav-link .mud-nav-link-icon {
        flex: 0 0 auto !important;
        
        /* Set a fixed margin between the icon and the text */
        margin-right: 16px !important;
        color: #e0681c; 
        
        /* Kill the default MudBlazor left margin */
        margin-left: 0 !important;
        width: auto !important;
    }

    .drawer-nav-link .mud-nav-link-text {
        flex: 0 0 auto !important;
        
        /* Ensure the text itself stays aligned left *relative to the icon* */
        text-align: left !important;
        color: #e0681c; 
        width: auto !important;
        margin: 0 !important;
    }
</style>

@code {

    bool _drawerOpen = false;

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private string GetSectionTitle()
    {
        if (Nav == null) return "LOADING...";
        
        // Simple logic to change the "OS" title based on URL
        var uri = Nav.Uri.ToLower();
        if (uri.Contains("/workshop")) return "WORKSHOP";
        if (uri.Contains("/blog")) return "DEV_LOG";
        if (uri.Contains("/arcade")) return "ARCADE";
        if (uri.Contains("/about")) return "CREDITS";
        if (uri.Contains("/community")) return "COMMUNITY";
        
        return "HOME";
    }

}
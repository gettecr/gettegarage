<div class="retro-container">
    <div class="retro-grid"></div>
    <div class="retro-horizon"></div>
</div>

<style>
    .retro-container {
        position: fixed;
        top: 0; left: 0;
        width: 100vw; height: 100vh;
        background-color: #121324; /* Deep Indigo */
        z-index: 0;
        overflow: hidden;
        pointer-events: none;
        perspective: 600px; /* Creates the 3D effect */
    }

    /* The moving floor */
    .retro-grid {
        position: absolute;
        bottom: -30%;
        left: -50%;
        width: 200%;
        height: 100%;
        background-image: 
            linear-gradient(#cf4024 1px, transparent 1px), 
            linear-gradient(90deg, #cf4024 1px, transparent 1px);
        background-size: 40px 40px; /* Grid square size */
        background-position: center bottom;
        transform: rotateX(60deg); /* Tilt it back */
        opacity: 0.35; 
        animation: grid-scroll 2s linear infinite;
        mask-image: linear-gradient(to top, black 40%, transparent 100%);
        
    }

    /* The glow at the horizon line */
    .retro-horizon {
        position: absolute;
        top:0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to bottom, rgba(246, 169, 31, 0.35) 0%, transparent 100%);
        mask-image: linear-gradient(to bottom, 
            transparent 10%, 
            black 40%, 
            black 60%, 
            transparent 100%
        );
        
        /* Webkit prefix for Safari/Chrome compatibility */
        -webkit-mask-image: linear-gradient(to bottom, 
             transparent 0%, 
            black 40%, 
            black 60%, 
            transparent 100%
        );
        pointer-events: none;
    }

    @@keyframes grid-scroll {
        0% { transform: rotateX(60deg) translateY(0); }
        100% { transform: rotateX(60deg) translateY(40px); } /* Move by exactly one square size */
    }
</style>
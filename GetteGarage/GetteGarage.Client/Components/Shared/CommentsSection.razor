@inject IJSRuntime JS
@rendermode InteractiveWebAssembly

<div class="comments-terminal">
    <div class="terminal-header">
         DISCUSSION // @Topic
    </div>

    <!-- This div will hold the Giscus iframe -->
    <div class="giscus"></div>
</div>

<style>
    .comments-terminal {
        border: 1px solid #333;
        background: rgba(0,0,0,0.5);
    }
    .terminal-header {
        background: #111;
        color: #f6a91f;
        padding: 8px 16px;
        font-family: 'Press Start 2P';
        font-size: 0.7rem;
        border-bottom: 1px solid #333;
    }
    /* Giscus needs some padding */
    .giscus { padding: 16px; }
</style>

@code {
    [Parameter] public string Topic { get; set; } = "GUESTBOOK";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadGiscus();
        }
    }

    private async Task LoadGiscus()
    {
        // PASTE YOUR CONFIG FROM GISCUS.APP HERE
        // Replace the values below with the ones generated for YOUR repo
        var script = @"
            var script = document.createElement('script');
            script.src = 'https://giscus.app/client.js';
            script.setAttribute('data-repo', 'gettecr/gettegarage');
            script.setAttribute('data-repo-id', 'R_kgDOQ-mJmQ');
            script.setAttribute('data-category', 'Comments');
            script.setAttribute('data-category-id', 'DIC_kwDOQ-mJmc4C3FHd');
            script.setAttribute('data-mapping', 'pathname');
            script.setAttribute('data-strict', '0');
            script.setAttribute('data-reactions-enabled', '1');
            script.setAttribute('data-emit-metadata', '0');
            script.setAttribute('data-input-position', 'top');
            script.setAttribute('data-theme', 'dark');
            script.setAttribute('data-lang', 'en');
            script.crossOrigin = 'anonymous';
            script.async = true;
            document.querySelector('.giscus').appendChild(script);
        ";

        await JS.InvokeVoidAsync("eval", script);
    }
}
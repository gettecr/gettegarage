@page "/fishing"
@using GetteGarage.Client.Models
@using GetteGarage.Client.Services
@using System.Threading.Tasks
@using System.Runtime.InteropServices
@using System.Text.Json
@inject FishingGameEngine Engine
@inject GetteGarage.Client.Services.AchievementService Achievements
@inject IJSRuntime JS
@implements IDisposable

<MudCard Elevation="0" Class="pa-0 d-flex flex-column" Style="height: 100%; background: #050510; border: 2px solid #2d2e45;">
    
    <div tabindex="0" @ref="gameContainer" @onkeydown="OnKeyDown" style="outline:none; flex: 0 0 280px;">
        <GameViewport Theme="@Engine.CurrentTheme" 
                      State="@_gameState" 
                      ActiveRod="@Engine.ActiveRod"
                      IsCasting="@_isCasting"
                      BobberX="@_bobberX"
                      LastCatch="@_lastCatch"
                      ShowSplash="@_showSplash"
                      SplashMessage="@_splashMessage">
            
            @if (_gameState == GameState.Minigame)
            {
                <MinigameHUD @ref="minigameHud"
                             ActiveRod="Engine.ActiveRod" 
                             TimeLeft="_minigameTimeLeft" 
                             TotalTime="_minigameTimeTotal"
                             OnComplete="HandleMinigameOutcome" />
            }
        </GameViewport>
    </div>

    <div class="flex-grow-1 height: 0">
        <MudTabs Elevation="0" Rounded="true" Class="fishing-tabs" PanelClass="pa-3" ActivePanelIndex="_activeTab"
         ActivePanelIndexChanged="OnTabChanged">
            

            <MudTabPanel Text="PLAY" Icon="@Icons.Material.Filled.Gamepad">
                <div class="gear-list">
                    <div class="d-flex justify-space-between align-center mb-4 mt-2">
                        <MudText Typo="Typo.body2" Class="text-warning" Style="font-family:'Press Start 2P'; font-size:0.7rem;">
                            FISH: @Engine.TotalFishCaught
                        </MudText>
                        <MudChip T="string" Color="Color.Info" Size="Size.Small">ROD: @Engine.ActiveRod.Name</MudChip>
                    </div>

                    <MudButton Variant="Variant.Filled" Color="GetButtonColor()" FullWidth="true" Class="py-3"
                               OnClick="HandleMainAction" 
                               onkeypress="space"
                               Disabled="@(_gameState == GameState.Minigame && Engine.ActiveRod.Type != RodType.Basic)">
                        @GetButtonText()
                    </MudButton>

                    <div class="flex-grow-1 custom-scroll py-3" style="min-height:0;">
                        @if (Engine.PersonalBests.Any())
                        {
                            <MudSimpleTable Dense="true" Hover="true" Class="rounded">
                                <thead>
                                    <tr><th>Fish</th><th>Caught</th><th>Best</th></tr>
                                </thead>
                                <tbody>
                                @foreach (var record in Engine.PersonalBests.Values.OrderBy(r => r.Name))
                                {
                                    <tr>
                                        <td>@record.Name</td>
                                        <td>@record.Count</td>
                                        <td>@record.MaxLength.ToString("F1") cm</td>
                                    </tr>
                                }
                                </tbody>
                            </MudSimpleTable>
                        }
                        else
                        {
                            <MudText Align="Align.Center" Color="Color.Inherit" Class="mt-8">Catch a fish to start your log!</MudText>
                        }
                    </div>

                    
                </div>
            </MudTabPanel>

            <!-- GEAR TAB -->
            <MudTabPanel Text="GEAR" Icon="@Icons.Material.Filled.Phishing">
                <!-- Inner scroll area -->
                <div class=" gear-list">
                     @foreach (var rod in GetVisibleRods())
                    {
                        <div class="d-flex justify-space-between align-center mb-2 pa-2 rounded" style="background: rgba(255,255,255,0.05);">
                            <div>
                                <MudText Typo="Typo.body2" Style="font-weight:bold;">@rod.Name</MudText>
                                <MudText Typo="Typo.caption" Style="color:#aaa;">@rod.Description</MudText>
                            </div>
                            @if (rod.IsUnlocked)
                            {
                                <MudButton Variant="@(Engine.ActiveRod.Id == rod.Id ? Variant.Filled : Variant.Outlined)" 
                                           Size="Size.Small" Color="Color.Success" OnClick="() => Engine.EquipRod(rod)">
                                    @(Engine.ActiveRod.Id == rod.Id ? "EQUIPPED" : "EQUIP")
                                </MudButton>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Warning"
                                           Disabled="@(Engine.TotalFishCaught < rod.UnlockCost)" OnClick="() => Engine.UnlockRod(rod)">
                                    UNLOCK (@rod.UnlockCost)
                                </MudButton>
                            }
                        </div>
                    }
                </div>
            </MudTabPanel>

            <MudTabPanel Text="RECORDS">
                <div class="pa-3 custom-scroll" style="height: 250px; overflow-y: auto;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">SELECT SPECIES</MudText>
                    
                    <div class="scroll-container mb-4">
                        <!-- 2. Set FixedContent="false" to allow items to be their own size -->
                        <MudToggleGroup T="string" Value="@_selectedSpecies" ValueChanged="OnSpeciesChanged" 
                                        SelectionMode="SelectionMode.SingleSelection" 
                                        Color="Color.Primary" CheckMark="false" FixedContent="false"
                                        Class="retro-toggle-group">
                            @foreach (var species in Engine.GetAllSpeciesNames())
                            {
                                <MudToggleItem Value="@species" Text="@species" />
                            }
                        </MudToggleGroup>
                    </div>

                    @if (_isLoadingLeaderboard)
                    {
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                    }
                    else if (!_leaderboard.Any())
                    {
                        <MudText Typo="Typo.caption" Style="color: #888;">No records found. Be the first!</MudText>
                    }
                    else
                    {
                        @for (int i = 0; i < _leaderboard.Count; i++)
                        {
                            // Create a local variable for the current record
                            var record = _leaderboard[i];
                            
                            // Calculate rank based on index (0-based index + 1)
                            int displayRank = i + 1;

                            <div class="d-flex justify-space-between align-center pa-2 mb-1" style="background: #111; border-bottom: 1px solid #333;">
                                <div class="d-flex align-center">
                                    <!-- Use displayRank here -->
                                    <MudText Typo="Typo.caption" 
                                            Color="@(displayRank == 1 ? Color.Warning : Color.Default)" 
                                            Style="font-family: 'Press Start 2P'; width: 25px;">
                                        #@displayRank
                                    </MudText>
                                    
                                    <MudText Typo="Typo.body2" Class="ml-2" Style="font-family: monospace; font-weight: bold;">
                                        @record.PlayerName
                                    </MudText>
                                </div>
                                
                                <MudText Typo="Typo.caption" Color="Color.Success">
                                    @record.Length.ToString("F2") cm
                                </MudText>
                            </div>
                        }
                    }
                </div>
            </MudTabPanel>
        </MudTabs>
    </div>

    @if (_showRecordDialog && _lastCatch != null)
    {
        <div class="record-overlay">
            <MudPaper Class="pa-4 record-dialog" Elevation="25">
                <MudText Typo="Typo.h5" Color="Color.Warning" Style="font-family: 'Press Start 2P'; animation: pulse 1s infinite;">
                    NEW WORLD RECORD!
                </MudText>
                
                <MudText Typo="Typo.body1" Align="Align.Center">
                    You caught a <b>@_lastCatch.Length.ToString(format: "N2") cm</b> @_lastCatch.Name!
                </MudText>
                <MudText Typo="Typo.caption" Align="Align.Center" Class="d-block mb-4" Style="color: #888;">
                    Enter your name in the Hall of Fame.
                </MudText>

                <MudTextField @bind-Value="_playerNameInput" Label="Initials (3 Letters)" MaxLength="3" 
                              Variant="Variant.Outlined" Class="mb-4" Style="font-family: monospace; text-transform: uppercase;" />

                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="SubmitRecord">
                    SUBMIT
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Default" FullWidth="true" Class="mt-2" OnClick="() => _showRecordDialog = false">
                    SKIP
                </MudButton>
            </MudPaper>
        </div>
    }
</MudCard>

<style>
    /* Custom Scrollbar */
    .custom-scroll::-webkit-scrollbar { width: 6px; }
    .custom-scroll::-webkit-scrollbar-thumb { background: #444; border-radius: 4px; }
    
    /* Flexbox overrides for MudTabs to fill height */
    .fishing-tabs { 
        display: flex; 
        flex-direction: column; 
        height: 100%; 
    }
    
    .fishing-tabs .mud-tabs-panels { 
        flex-grow: 1; 
        height: 0; /* Let the container grow, but don't give it a fixed height */
    }

    .fishing-tabs .mud-tab-panel {
        height: 100%;
    }
    
    .gear-list { 
        height: 100%; 
        overflow-y: auto; 
        padding-right: 5px; 
    }

    .record-overlay {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        background: rgba(0,0,0,0.8); z-index: 100;
        display: flex; align-items: center; justify-content: center;
    }
    .record-dialog {
        background: #111; border: 2px solid #f6a91f; text-align: center;
    }

    .retro-toggle-group {
        display: flex !important;
        flex-wrap: nowrap !important; /* Force one line */
        width: max-content; /* Allow it to grow as wide as the words */
        background: #111 !important;
        border: 1px solid #333 !important;
    }

    /* Force each button to keep its shape */
    .retro-toggle-group .mud-toggle-item {
        flex-shrink: 0 !important;
        padding: 0 12px !important;
    }

    /* The Scrollbar styling */
    .scroll-container {
        overflow-x: auto;
        width: 100%;
        scrollbar-width: thin;
        scrollbar-color: #f6a91f #111;
    }

    .scroll-container::-webkit-scrollbar {
        height: 4px;
    }
    .scroll-container::-webkit-scrollbar-thumb {
        background: #f6a91f;
        border-radius: 2px;
    }

    @@keyframes pulse { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }
</style>

@code {
    private string _splashMessage = ""; 
    private ElementReference gameContainer;
    private MinigameHUD minigameHud;


    // View State
    private GameState _gameState = GameState.Idle;
    private bool _isCasting = false;
    private int _bobberX = 50;
    private bool _showSplash = false;
    private CaughtFish _lastCatch;

    // Timers
    private Timer? _actionTimer;
    private System.Timers.Timer _minigameTimer;
    private double _minigameTimeTotal = 2000;
    private double _minigameTimeLeft = 2000;

    private bool _showRecordDialog = false;
    private string _playerNameInput = "";
    private int _activeTab = 0;
    private string _selectedSpecies = "Minnow"; // Default starting fish
    private bool _isLoadingLeaderboard = false;
    private List<FishingRecord> _leaderboard = new();
    private CancellationTokenSource? _biteCts;

    [Inject] private HttpClient Http { get; set; }

    public class FishingRecord
    {
        public string PlayerName { get; set; } = "";
        public string FishName { get; set; } = "";
        public double Length { get; set; }
    }

    protected override void OnInitialized()
    {
        // 1. Setup the hardcoded ecosystem immediately so the HTML can draw the dropdown
        Engine.Initialize(); 
        
        // Ensure we have a default selected species for the dropdown
        var allSpecies = Engine.GetAllSpeciesNames();
        if (allSpecies.Any())
        {
            _selectedSpecies = allSpecies.First();
        }

        _minigameTimer = new System.Timers.Timer(50);
        _minigameTimer.Elapsed += (s, e) => MinigameTick();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 2. Load user save data (requires JS, so it stays here)
            await Engine.LoadAsync(); 
            StateHasChanged();
        }
    }

    private async Task HandleMainAction()
    {
        if (_gameState == GameState.Idle) await CastLine();
        else if (_gameState == GameState.Waiting) HandleMinigameOutcome(false); 
        else if (_gameState == GameState.Minigame && Engine.ActiveRod.Type == RodType.Basic) HandleMinigameOutcome(true); 
    }

    private async Task CastLine()
    {
        _gameState = GameState.Casting;
        _isCasting = true;
        _bobberX = new Random().Next(40, 80);

        await Task.Delay(500);
        _gameState = GameState.Waiting;
        _isCasting = false;
        StateHasChanged();

        _actionTimer = new Timer(_ => TriggerBite(), null, new Random().Next(2000, 4000), Timeout.Infinite);
    }

    private void TriggerBite()
    {
        if (_gameState != GameState.Waiting) return;
        _gameState = GameState.Minigame;

        _minigameTimeTotal = Engine.ActiveRod.Type switch { 
            RodType.Basic => 1000, 
            RodType.Qte => Engine.ActiveRod.Difficulty switch { QteDifficulty.Easy => 6000, QteDifficulty.Medium => 3000, QteDifficulty.Hard => 6000, QteDifficulty.Expert => 6000, _ => 6000 },
            RodType.Ascii => 4000, 
            RodType.Rhythm => 4000,
            _ => 2000 
        };

        _minigameTimeLeft = _minigameTimeTotal;

        InvokeAsync(async () => {
            StateHasChanged();
            _minigameTimer.Start();
            await Task.Delay(50);

            try 
            {
                if (Engine.ActiveRod.Type == RodType.Ascii) 
                    await JS.InvokeVoidAsync("eval", "document.getElementById('hacker-input').focus()");
                else 
                    await gameContainer.FocusAsync(); 
            }
            catch { }
        });
    }

    private void MinigameTick()
    {
        _minigameTimeLeft -= 50;
        if (_minigameTimeLeft <= 0) InvokeAsync(() => HandleMinigameOutcome(false));
        else InvokeAsync(StateHasChanged);
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        switch (_gameState)
        {
            case GameState.Idle:
                if (e.Code == "Space")
                {
                    _ = HandleMainAction();
                }
                break;

            case GameState.Waiting:
                if (e.Code == "Space")
                {
                    _ = HandleMainAction();
                }
                break;

            case GameState.Minigame:
                minigameHud?.HandleExternalKeyPress(e);
                break;
        }
    }
    private IEnumerable<RodDef> GetVisibleRods()
    {
        var visibleRods = new List<RodDef>();
        bool nextUnlockableFound = false;

        // The list in the Engine is already sorted by cost
        foreach (var rod in Engine.AvailableRods)
        {
            if (rod.IsUnlocked)
            {
                visibleRods.Add(rod);
            }
            // If the rod is locked AND we haven't found the next one to show yet...
            else if (!nextUnlockableFound)
            {
                // ...show this one, and then stop showing any more locked rods.
                visibleRods.Add(rod);
                nextUnlockableFound = true;
            }
        }
        return visibleRods;
    }

    private async Task HandleMinigameOutcome(bool success)
    {
        _minigameTimer.Stop();
        _actionTimer?.Dispose();
        _gameState = GameState.Idle;

        if (success)
        {
            _lastCatch = await Engine.GenerateCatch();
            _splashMessage = ""; // Clear any error message

            try 
            {
                var isRecord = await Http.GetFromJsonAsync<bool>($"api/fishing/check-record/{_lastCatch.Name}/{_lastCatch.Length}");
                if (isRecord)
                {
                    // Trigger the UI Dialog
                    _showRecordDialog = true;
                }
            }
            catch 
            {
                // Ignore if server is offline, just proceed normally
            }
        }
        else
        {
            _lastCatch = null; // Ensure we don't show a fish
            _splashMessage = "It got away..."; // Set the feedback message
        }

        // Show the splash for both success and failure
        _showSplash = true;
        Task.Delay(2000).ContinueWith(_ => { _showSplash = false; InvokeAsync(StateHasChanged); });
        StateHasChanged();
    
    }

    private async Task SubmitRecord()
    {
        if (string.IsNullOrWhiteSpace(_playerNameInput)) _playerNameInput = "AAA";
        
        var record = new 
        {
            PlayerName = _playerNameInput.ToUpper(),
            FishName = _lastCatch.Name,
            Length = _lastCatch.Length,
            RodUsed = Engine.ActiveRod.Name.ToString()
        };

        try
        {
            await Http.PostAsJsonAsync("api/fishing", record);
            await Achievements.Unlock(
                "fishing_record", 
                "Angler Legend", 
                $"Set a new world record for {_lastCatch.Name}!"
            );

        }
        catch { /* Handle network error */ }

        _showRecordDialog = false;
    }


    private async Task OnTabChanged(int index)
    {
        _activeTab = index;
        
        // Index 2 is the third tab (Records)
        if (index == 1 || index == 2) // They clicked away
        {
            // If they had a line in the water, cancel it!
            if (_gameState == GameState.Waiting || _gameState == GameState.Casting || _gameState == GameState.Minigame)
            {
                CancelCast("Line reeled in (Tab switched).");
            }
            if (index == 2)
            {
                // Fetch the high scores
                await LoadLeaderboard();
            }
        }
    }

    private async Task OnSpeciesChanged(string species)
    {
        _selectedSpecies = species;
        await LoadLeaderboard();
    }

    private async Task LoadLeaderboard()
    {
        _isLoadingLeaderboard = true;
        StateHasChanged();
        try
        {
            
            var options = new JsonSerializerOptions 
            { 
                PropertyNameCaseInsensitive = true 
            };

            var results = await Http.GetFromJsonAsync<List<FishingRecord>>($"api/fishing/top/{_selectedSpecies}", options);
            
            if (results != null) 
            {
                _leaderboard = results;
            }
            else
            {
                Console.WriteLine($"[Leaderboard Error] Null Values");
            }
        }
        catch (Exception ex)
        {
            // Temporary debug log so you can see exactly WHY it failed in the browser console
            Console.WriteLine($"[Leaderboard Error] {ex.Message}");
            _leaderboard.Clear();
        }

        _isLoadingLeaderboard = false;
        StateHasChanged();
    }

    private void CancelCast(string reason)
    {
        Console.WriteLine(reason);

        if (_biteCts != null)
        {
            _biteCts.Cancel();
            _biteCts.Dispose();
            _biteCts = null;
        }

        if (_actionTimer != null)
        {
            _actionTimer.Change(Timeout.Infinite, Timeout.Infinite);
            _actionTimer.Dispose();
            _actionTimer = null;
        }

        _gameState = GameState.Idle;
        _isCasting = false;

        InvokeAsync(StateHasChanged);
    }

    private string GetButtonText() => _gameState switch { GameState.Idle => "CAST LINE", GameState.Waiting => "WAIT...", GameState.Minigame => Engine.ActiveRod.Type == RodType.Basic ? "REEL IN!" : "FIGHTING!", _ => "..." };
    private Color GetButtonColor() => _gameState switch { GameState.Minigame => Color.Error, GameState.Waiting => Color.Surface, _ => Color.Primary };

    public void Dispose()
    {
        Engine.OnStateChanged -= StateHasChanged;
        _minigameTimer?.Dispose();
        _actionTimer?.Dispose();
    }
}
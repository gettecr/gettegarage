@using MudBlazor

<MudPaper Class="studio-card">
    <div class="d-flex flex-column" style="height: 100%;">
        
        <!-- Header / Status -->
        <div class="d-flex justify-space-between align-center mb-2">
            <MudChip T="string" Color="@StatusColor" Size="Size.Small" Variant="Variant.Filled" Class="press-start-chip">
                @Status
            </MudChip>
            <MudText Typo="Typo.caption" Style="font-family: monospace; opacity: 0.7;">@Version</MudText>
        </div>

        <!-- Title -->
        <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-2" Style="font-family: 'Press Start 2P'; line-height: 1.4;">
            @Title
        </MudText>

        @if (!string.IsNullOrEmpty(Url))
        {
            <MudImage Src="@Url" 
                      Fluid="true" 
                      Height="160" 
                      ObjectFit="ObjectFit.Cover" 
                      Class="rounded-lg mb-3 my-image-border" />
        }

        <!-- Description -->
        <MudText Typo="Typo.body2" Class="mb-4" Style="font-family: 'Rajdhani'; font-size: 1rem;">
            @Description
        </MudText>
        <MudDivider Class="mt-auto mb-3 flex-grow-0" Style="flex-shrink: 0;"/>
        
        <!-- Footer -->
        <div class="d-flex justify-space-between align-center">
            <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-family: monospace;">
                @TechStack
            </MudText>
            
            @if(!string.IsNullOrEmpty(PlayLink))
            {
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="@PlayLink" Size="Size.Small">
                    LAUNCH
                </MudButton>
            }
        </div>
    </div>
</MudPaper>

<style>
    .studio-card {
        background: #0a0a1f;
        border: 2px solid #333;
        transition: all 0.2s;
        padding: 1.5rem;
        height: 100%;
    }
    .studio-card:hover {
        border-color: #f6a91f;
        transform: translateY(-4px);
        box-shadow: 0 0 20px rgba(246, 169, 31, 0.15);
    }
    .press-start-chip { font-family: 'Press Start 2P'; font-size: 0.6rem; }
</style>

@code {
    [Parameter] public string Title { get; set; }
    [Parameter] public string Version { get; set; }
    [Parameter] public string Url {get; set;}
    [Parameter] public string Status { get; set; }
    [Parameter] public Color StatusColor { get; set; }
    [Parameter] public string Description { get; set; }
    [Parameter] public string TechStack { get; set; }
    [Parameter] public string PlayLink { get; set; }
}
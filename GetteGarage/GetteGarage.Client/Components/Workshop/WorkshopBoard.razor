@using MudBlazor
@rendermode InteractiveWebAssembly
@inject IDialogService DialogService
@inject IJSRuntime JS

<!-- 1. THE STICKY SUB-NAV -->
<div class="workshop-sub-nav">
    <MudButton OnClick="@(() => ScrollTo("active-titles"))" Color="Color.Primary" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Gamepad">
        ACTIVE
    </MudButton>
    <MudButton OnClick="@(() => ScrollTo("prototypes"))" Color="Color.Secondary" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Science" Class="d-none d-sm-inline-flex">
        PROTOTYPES
    </MudButton>
    <MudButton OnClick="@(() => ScrollTo("art-assets"))" Color="Color.Info" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.Brush" Class="d-none d-sm-inline-flex">
        ART
    </MudButton>
    <MudButton OnClick="@(() => ScrollTo("legacy"))" Color="Color.Tertiary" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.History">
        LEGACY
    </MudButton>
</div>

<!-- 2. SECTION: ACTIVE TITLES -->
<section id="active-titles" class="workshop-section">
    <MudText Typo="Typo.h5" Color="Color.Primary" Class="mb-4" Style="font-family: 'Press Start 2P'">
        ACTIVE TITLES
    </MudText>
    
    <MudGrid>
        <!-- 1. Big Larry -->
        <MudItem xs="12" md="6">
            <StudioGameCard 
                Title="Big Larry's Beach Baseball" 
                Version="v1.0" Status="LIVE" StatusColor="Color.Tertiary"
                Description="'Shooting gallery' gameplay with batting cage timing and Larry. What's not to love?"
                TechStack="Godot, WebGL"
                Url="/art/big_larrys_thumbnail.png"
                PlayLink="/play/big-larrys-beach-baseball" />
        </MudItem>

        <!-- 2. Tidebreaker -->
        <MudItem xs="12" md="6">
            <StudioGameCard 
                Title="Tidebreaker" 
                Version="v1.2" Status="LIVE" StatusColor="Color.Tertiary"
                Description="Breakout. But with 100% more water."
                TechStack="Godot, WebGL"
                Url="/art/tidebreaker_thumbnail.png"
                PlayLink="/play/tidebreaker" />
        </MudItem>

        <!-- 3. Fishing RPG -->
        <MudItem xs="12" md="4">
            <StudioGameCard 
                Title="Idle Fishing RPG" 
                Version="v1.0" Status="BUILT-IN" StatusColor="Color.Info"
                Description="A reactive idle game running in your browser's background. Cast lines and catch fish."
                TechStack="Blazor WASM"
                PlayLink="#" /> 
        </MudItem>

        <!-- 4. Dev Simulator -->
        <MudItem xs="12" md="4">
            <StudioGameCard 
                Title="Dev Simulator" 
                Version="v2.4" Status="BUILT-IN" StatusColor="Color.Info"
                Description="Write code, drink coffee, squash bugs and upgrade your system."
                TechStack="Blazor WASM"
                PlayLink="#" />
        </MudItem>

        <!-- 5. Gette Garage (The Site) -->
        <MudItem xs="12" md="4">
            <StudioGameCard 
                Title="Gette Garage OS" 
                Version="v2.0" Status="SYSTEM" StatusColor="Color.Warning"
                Description="This website. Full-stack Azure web app."
                TechStack=".NET 8, Azure"
                PlayLink="https://github.com/gettecr/" />
        </MudItem>
    </MudGrid>
</section>

<MudDivider Class="my-12" Style="opacity: 0.2; border-color: #f6a91f;" />

<!-- 3. SECTION: PROTOTYPES & R&D -->
<section id="prototypes" class="workshop-section">
    <MudText Typo="Typo.h5" Color="Color.Secondary" Class="mb-4" Style="font-family: 'Press Start 2P'">
        PROTOTYPES & R&D
    </MudText>

    <!-- PRODUCTION ROADMAP -->
    <MudText Typo="Typo.h6" Color="Color.Warning" Class="mb-4 mt-6" Style="font-family: 'Press Start 2P'; font-size: 0.8rem;">
        /// STUDIO ROADMAP
    </MudText>

    <MudPaper Class="pa-6 mb-12" Style="background: rgba(0,0,0,0.2); border: 1px dashed #f6a91f;">
        <MudTimeline TimelinePosition="TimelinePosition.Start">
            <MudTimelineItem Color="Color.Success" Size="Size.Small">
                <ItemOpposite><MudText Typo="Typo.caption" Color="Color.Success">NOW</MudText></ItemOpposite>
                <ItemContent>
                    <MudText Typo="Typo.subtitle2" Color="Color.Success" Style="font-family: 'Press Start 2P'; font-size: 0.7rem;">GETTE GARAGE LAUNCH</MudText>
                    <MudText Typo="Typo.body2">Personal site deployed. Fishing RPG v1.0 in progress.</MudText>
                </ItemContent>
            </MudTimelineItem>

            <MudTimelineItem Color="Color.Warning" Size="Size.Small">
                <ItemOpposite><MudText Typo="Typo.caption" Color="Color.Warning">Q3 2025</MudText></ItemOpposite>
                <ItemContent>
                    <MudText Typo="Typo.subtitle2" Color="Color.Warning" Style="font-family: 'Press Start 2P'; font-size: 0.7rem;">FOR THE BIRDS</MudText>
                    <MudText Typo="Typo.body2">Short demo of main title: farming sim meets viva pinata</MudText>
                </ItemContent>
            </MudTimelineItem>

            <MudTimelineItem Color="Color.Dark" Size="Size.Small">
                <ItemOpposite><MudText Typo="Typo.caption" Style="color: #666;">TBD</MudText></ItemOpposite>
                <ItemContent>
                    <MudText Typo="Typo.subtitle2" Style="color: #888; font-family: 'Press Start 2P'; font-size: 0.7rem;">STEAM DEBUT</MudText>
                    <MudText Typo="Typo.body2" Style="color: #888;">PC Port of flagship title with expanded mechanics.</MudText>
                </ItemContent>
            </MudTimelineItem>
        </MudTimeline>
    </MudPaper>

    <!-- PROTOTYPE GRID -->
    <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-4" Style="font-family: 'Press Start 2P'; font-size: 0.8rem;">
        /// EXPERIMENTAL CONCEPTS AND WORKS IN PROGRESS
    </MudText>

    <MudGrid>
        <MudItem xs="12" md="6">
            <StudioGameCard 
                Title="For The Birds" 
                Version="ALPHA 0.3" Status="PROTOTYPE" StatusColor="Color.Warning"
                Description="Farming sim where you manage and grow your bird sanctuary"
                TechStack="Godot 4"
                PlayLink="#" />
        </MudItem>

        <MudItem xs="12" md="6">
            <StudioGameCard 
                Title="Trash Bandit" 
                Version="CONCEPT" Status="R&D" StatusColor="Color.Secondary"
                Description="Raccoon jump good in a DK '94 style platformer"
                TechStack="Godot 4"
                PlayLink="#" />
        </MudItem>
    </MudGrid>
</section>

<MudDivider Class="my-12" Style="opacity: 0.2; border-color: #f6a91f;" />

<!-- 4. SECTION: ART & ASSETS -->
<section id="art-assets" class="workshop-section">
    <MudText Typo="Typo.h5" Color="Color.Info" Class="mb-4" Style="font-family: 'Press Start 2P'">
        ART & ASSETS
    </MudText>

    <MudGrid>
        @foreach (var item in PortfolioItems)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="3" Class="cursor-pointer hover-zoom" @onclick="() => OpenImage(item)" Style="background: #0a0a1f; border: 1px solid #333;">
                    <MudCardMedia Image="@item.Url" Height="250" Style="background-size: cover;" />
                    <MudCardContent>
                        <MudText Typo="Typo.h6" Style="font-family: 'Rajdhani'; font-weight: bold; color: #e0e0e0;">@item.Title</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Style="font-family: monospace;">@item.Category</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</section>

<MudDivider Class="my-12" Style="opacity: 0.2; border-color: #f6a91f;" />

<!-- 5. SECTION: LEGACY ARCHIVES -->
<section id="legacy" class="workshop-section">
    <MudText Typo="Typo.h5" Color="Color.Tertiary" Class="mb-4" Style="font-family: 'Press Start 2P'">
        LEGACY ARCHIVES
    </MudText>
    <MudText Typo="Typo.body1" Class="mb-4" Color="Color.Secondary" Style="font-family:'Press Start 2P'; font-size:0.7rem;">
        /// ARCHIVAL WORKS
    </MudText>
    
    <MudGrid>
        <MudItem xs="12" sm="6" md="4">
            <LegacyCard Title="Physics Education Research" Role="PhD Physics" 
                        Desc="Research on cognitive theories of learning and intuition to understand student difficulties in physics." />
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <LegacyCard Title="ML/AI Applications" Role="Lead Data Scientist" 
                        Desc="Developed Image matching, NLP classifiers, quarterly KPI prediction models etc. using AWS/Python." />
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <LegacyCard Title="Cloud Infrastructure" Role="Tech Lead (OPM)" 
                        Desc="Modernized government HR software using Azure, Databricks, and AI-powered workflows." />
        </MudItem>
        <MudItem xs="12" sm="6" md="4">
            <LegacyCard Title="Spectral Analysis" Role="MS Astrophysics" 
                        Desc="Analyzed spectral data for 100 ATLASGAL sources to find nitrogen hydrides in massive star forming regions." />
        </MudItem>
    </MudGrid>
</section>

<style>
    /* The Sticky Sub-Nav */
    .workshop-sub-nav {
        position: sticky;
        top: 64px; /* Docks right under your main top app bar */
        z-index: 5;
        
        /* Indigo Glassmorphism */
        background: rgba(18, 19, 36, 0.95); 
        backdrop-filter: blur(8px);
        
        padding: 10px 0;
        margin-bottom: 2rem;
        border-bottom: 1px solid #333;
        
        display: flex;
        gap: 1rem;
        overflow-x: auto; 
    }

    /* Invisible bumper to stop the header from covering section titles when you jump to them */
    .workshop-section {
        scroll-margin-top: 130px; 
    }

    /* Hover effect for the Art Cards */
    .hover-zoom {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-zoom:hover {
        transform: translateY(-5px);
        box-shadow: 0 5px 15px rgba(246, 169, 31, 0.2);
        border-color: #f6a91f !important;
    }
</style>

@code {
    // 1. The Data Model
    public class ArtItem
    {
        public string Title { get; set; } = "";
        public string Category { get; set; } = ""; 
        public string Url { get; set; } = "";
        public string Description { get; set; } = "";
    }

    // 2. The Data List
    private List<ArtItem> PortfolioItems = new List<ArtItem>
    {
        new ArtItem { Title = "Cyberpunk City", Category = "Concept Art", Url = "/art/sanctuary_sketch_artopoeia_palette.png", Description = "A dystopian future city." },
        new ArtItem { Title = "Hero Sprite", Category = "Pixel Art", Url = "/art/sprite.png", Description = "Main character walk cycle." },
        new ArtItem { Title = "Space Station", Category = "3D Render", Url = "/art/station.jpg", Description = "Blender render of the station." },
    };

    // 3. The Dialog Logic
    private void OpenImage(ArtItem item)
    {
        // Safe generic DialogParameters for MudBlazor v7
        var parameters = new DialogParameters<ArtDialog> { { x => x.Item, item } };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        
        DialogService.ShowAsync<ArtDialog>(item.Title, parameters, options);
    }

    private async Task ScrollTo(string id)
    {
        await JS.InvokeVoidAsync("scrollToElement", id);
    }
}
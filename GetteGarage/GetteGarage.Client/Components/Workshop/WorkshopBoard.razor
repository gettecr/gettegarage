@using MudBlazor
@rendermode InteractiveWebAssembly

<MudTabs Elevation="0" Rounded="true" Color="Color.Transparent" SliderColor="Color.Primary" ApplyEffectsToContainer="true" PanelClass="pt-8">
    
    <!-- TAB 1: ACTIVE TITLES -->
    <MudTabPanel Text="ACTIVE TITLES" Icon="@Icons.Material.Filled.Gamepad">
        <MudGrid>
            <!-- 1. Big Larry -->
            <MudItem xs="12" md="6">
                <StudioGameCard 
                    Title="Big Larry's Beach Baseball" 
                    Version="v1.0" Status="LIVE" StatusColor="Color.Tertiary"
                    Description="'Shooting gallery' gameplay with batting cage timing and Larry. What's not to love?"
                    TechStack="Godot, WebGL"
                    Url="/art/big_larrys_thumbnail.png"
                    PlayLink="/play/big-larrys-beach-baseball" />
            </MudItem>

            <!-- 2. Tidebreaker -->
            <MudItem xs="12" md="6">
                <StudioGameCard 
                    Title="Tidebreaker" 
                    Version="v1.2" Status="LIVE" StatusColor="Color.Tertiary"
                    Description="Breakout. But with 100% more water."
                    TechStack="Godot, WebGL"
                    Url="/art/tidebreaker_thumbnail.png"
                    PlayLink="/play/tidebreaker" />
            </MudItem>

            <!-- 3. Fishing RPG -->
            <MudItem xs="12" md="4">
                <StudioGameCard 
                    Title="Idle Fishing RPG" 
                    Version="v1.0" Status="BUILT-IN" StatusColor="Color.Info"
                    Description="A reactive idle game running in your browser's background. Cast lines and catch fish."
                    TechStack="Blazor WASM"
                    PlayLink="#" /> <!-- Clicking opens global game -->
            </MudItem>

            <!-- 4. Dev Simulator -->
            <MudItem xs="12" md="4">
                <StudioGameCard 
                    Title="Dev Simulator" 
                    Version="v2.4" Status="BUILT-IN" StatusColor="Color.Info"
                    Description="Write code, drink coffee, squash bugs and upgrade your system."
                    TechStack="Blazor WASM"
                    PlayLink="#" />
            </MudItem>

            <!-- 5. Gette Garage (The Site) -->
            <MudItem xs="12" md="4">
                <StudioGameCard 
                    Title="Gette Garage OS" 
                    Version="v2.0" Status="SYSTEM" StatusColor="Color.Warning"
                    Description="This website. Full-stack Azure web app."
                    TechStack=".NET 8, Azure"
                    PlayLink="https://github.com/gettecr/" />
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    <!-- TAB 2: PROTOTYPES (R&D) -->
    <MudTabPanel Text="PROTOTYPES & R&D" Icon="@Icons.Material.Filled.Science">
        
        <!-- 1. PRODUCTION ROADMAP -->
        <MudText Typo="Typo.h6" Color="Color.Warning" Class="mb-4 mt-4" Style="font-family: 'Press Start 2P'; font-size: 0.8rem;">
            /// STUDIO ROADMAP
        </MudText>

        <MudPaper Class="pa-6 mb-12" Style="background: rgba(0,0,0,0.2); border: 1px dashed #f6a91f;">
            <MudTimeline TimelinePosition="TimelinePosition.Start">
                
                <MudTimelineItem Color="Color.Success" Size="Size.Small">
                    <ItemOpposite>
                        <MudText Typo="Typo.caption" Color="Color.Success">NOW</MudText>
                    </ItemOpposite>
                    <ItemContent>
                        <MudText Typo="Typo.subtitle2" Color="Color.Success" Style="font-family: 'Press Start 2P'; font-size: 0.7rem;">
                            GETTE GARAGE LAUNCH
                        </MudText>
                        <MudText Typo="Typo.body2">Personal site deployed. Fishing RPG v1.0 in progress.</MudText>
                    </ItemContent>
                </MudTimelineItem>

                <MudTimelineItem Color="Color.Warning" Size="Size.Small">
                    <ItemOpposite>
                        <MudText Typo="Typo.caption" Color="Color.Warning">Q3 2025</MudText>
                    </ItemOpposite>
                    <ItemContent>
                        <MudText Typo="Typo.subtitle2" Color="Color.Warning" Style="font-family: 'Press Start 2P'; font-size: 0.7rem;">
                            FOR THE BIRDS
                        </MudText>
                        <MudText Typo="Typo.body2">Short demo of main title: farming sim meets viva pinata</MudText>
                    </ItemContent>
                </MudTimelineItem>

                <MudTimelineItem Color="Color.Dark" Size="Size.Small">
                    <ItemOpposite>
                        <MudText Typo="Typo.caption" Style="color: #666;">TBD</MudText>
                    </ItemOpposite>
                    <ItemContent>
                        <MudText Typo="Typo.subtitle2" Style="color: #888; font-family: 'Press Start 2P'; font-size: 0.7rem;">
                            STEAM DEBUT
                        </MudText>
                        <MudText Typo="Typo.body2" Style="color: #888;">PC Port of flagship title with expanded mechanics.</MudText>
                    </ItemContent>
                </MudTimelineItem>

            </MudTimeline>
        </MudPaper>

        <!-- 2. PROTOTYPE GRID -->
        <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-4" Style="font-family: 'Press Start 2P'; font-size: 0.8rem;">
            /// EXPERIMENTAL CONCEPTS AND WORKS IN PROGRESS
        </MudText>

        <MudGrid>
            <MudItem xs="12" md="6">
                <StudioGameCard 
                    Title="For The Birds" 
                    Version="ALPHA 0.3" Status="PROTOTYPE" StatusColor="Color.Warning"
                    Description="Farming sim where you manage and grow your bird sanctuary"
                    TechStack="Godot 4"
                    PlayLink="#" />
            </MudItem>

            <MudItem xs="12" md="6">
                <StudioGameCard 
                    Title="Trash Bandit" 
                    Version="CONCEPT" Status="R&D" StatusColor="Color.Secondary"
                    Description="Raccoon jump good in a DK '94 style platformer"
                    TechStack="Godot 4"
                    PlayLink="#" />
            </MudItem>
        </MudGrid>
    </MudTabPanel>

    <!-- TAB 3: LEGACY (Resume) -->
    <MudTabPanel Text="LEGACY ARCHIVES" Icon="@Icons.Material.Filled.History">
        <MudText Typo="Typo.body1" Class="mb-4" Color="Color.Secondary" Style="font-family:'Press Start 2P'; font-size:0.7rem;">
            /// ARCHIVAL WORKS
        </MudText>
        <MudGrid>
            <MudItem xs="12" sm="6" md="4">
                <LegacyCard Title="Physics Education Research" Role="PhD Physics" 
                            Desc="Research on cognitive theories of learning and intuition to understand student difficulties in physics." />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <LegacyCard Title="ML/AI Applications" Role="Lead Data Scientist" 
                            Desc="Developed Image matching, NLP classifiers, quarterly KPI prediction models etc. using AWS/Python." />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <LegacyCard Title="Cloud Infrastructure" Role="Tech Lead (OPM)" 
                            Desc="Modernized government HR software using Azure, Databricks, and AI-powered workflows." />
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <LegacyCard Title="Spectral Analysis" Role="MS Astrophysics" 
                            Desc="Analyzed spectral data for 100 ATLASGAL sources to find nitrogen hydrides in massive star forming regions." />
            </MudItem>
        </MudGrid>
    </MudTabPanel>

</MudTabs>
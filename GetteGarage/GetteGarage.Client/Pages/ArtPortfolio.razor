@page "/gallery"
@rendermode InteractiveWebAssembly
@inject IDialogService DialogService

@* <MudDialogProvider /> *@

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-8">
    <GetteGarage.Client.Components.Shared.HUDHeader Title="ART & ASSETS" Subtitle="A COLLECTION OF SPRITES, CONECPT ART, AND ANIMATIONS"/>

    <!-- The Grid -->
    <MudGrid>
        @foreach (var item in PortfolioItems)
        {
            <MudItem xs="12" sm="6" md="4">
                <!-- Hover effect helper class makes it interactive -->
                <MudCard Elevation="3" Class="cursor-pointer hover-zoom" @onclick="() => OpenImage(item)">
                    <MudCardMedia Image="@item.Url" Height="250" Style="background-size: cover;" />
                    <MudCardContent>
                        <MudText Typo="Typo.h6">@item.Title</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@item.Category</MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    // 1. The Data Model
    public class ArtItem
    {
        public string Title { get; set; } = "";
        public string Category { get; set; } = ""; // e.g., "Pixel Art", "3D Model"
        public string Url { get; set; } = "";
        public string Description { get; set; } = "";
    }

    // 2. The Data List
    private List<ArtItem> PortfolioItems = new List<ArtItem>
    {
        new ArtItem { Title = "Cyberpunk City", Category = "Concept Art", Url = "/art/sanctuary_sketch_artopoeia_palette.png", Description = "A dystopian future city." },
        new ArtItem { Title = "Hero Sprite", Category = "Pixel Art", Url = "/art/sprite.png", Description = "Main character walk cycle." },
        new ArtItem { Title = "Space Station", Category = "3D Render", Url = "/art/station.jpg", Description = "Blender render of the station." },
    };

    // 3. The Dialog Logic
    private void OpenImage(ArtItem item)
    {
        var parameters = new DialogParameters { ["Item"] = item };
        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        
        // We create a simple inline Dialog here, or you can make a separate component
        DialogService.ShowAsync<ArtDialog>(item.Title, parameters, options);
    }
}

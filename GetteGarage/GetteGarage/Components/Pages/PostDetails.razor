@page "/blog/{Slug}"
@using GetteGarage.Services
@inject BlogService BlogService
@inject NavigationManager Nav

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8 mb-8">
    
    <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/blog" Class="mb-4">Back to List</MudButton>

    @if (CurrentPost == null)
    {
         <div class="d-flex justify-center mt-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else
    {
        <MudPaper Elevation="0" Class="pa-4">
            <MudText Typo="Typo.h3" GutterBottom="true" Class="responsive-blog-title">@CurrentPost.Title</MudText>
            <MudText Typo="Typo.subtitle2" Class="mb-6" Color="Color.Secondary">
                Published on @CurrentPost.PubDate.ToLongDateString()
            </MudText>
            
            <MudDivider Class="mb-6"/>

            <div class="blog-content">
                @((MarkupString)CurrentPost.Content) 
            </div>

            <MudDivider Class="mt-8 mb-4"/>
            
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="@CurrentPost.Link" Target="_blank">
                Comment on Substack
            </MudButton>
        </MudPaper>
    }
</MudContainer>

<style>
    .responsive-blog-title {
        /* Standard desktop font family from your theme */
        font-family: 'Press Start 2P', cursive;
        line-height: 1.4;
        color: #e0681c; 
        
        /* Force words to wrap so they don't break the layout */
        word-break: break-word;
        overflow-wrap: break-word;
    }

    /* MOBILE TWEAK (Phones) */
    @@media (max-width: 600px) {
        .responsive-blog-title {
            /* Drop from default ~3rem down to 1.2rem */
            font-size: 1.2rem !important; 
            margin-top: 1rem;
        }
    }

    /* TABLET TWEAK */
    @@media (min-width: 601px) and (max-width: 960px) {
        .responsive-blog-title {
            font-size: 1.8rem !important;
        }
    }
</style>

@code {
    [Parameter] public string Slug { get; set; } = "";
    private BlogPost? CurrentPost;

    protected override async Task OnInitializedAsync()
    {
        // Fetch all posts (RSS feeds don't allow fetching just one by ID usually)
        var allPosts = await BlogService.GetPostsAsync();

        // Find the one matching the slug
        CurrentPost = allPosts.FirstOrDefault(p => p.Slug == Slug);

        // If not found, go back to list
        if (CurrentPost == null)
        {
            Nav.NavigateTo("/blog");
        }
    }
}
@page "/community"
@using GetteGarage.Client.Components.Shared

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-16">
    
    <!-- HUD Header -->

    <GetteGarage.Client.Components.Shared.HUDHeader Title="THE COMMUNITY" Subtitle="VISITORS AND DISCUSSION"/> 

    <MudGrid>
        <!-- LEFT COLUMN: Badges & Webrings -->
        <MudItem xs="12" md="5">
            
            <MudPaper Class="pa-6" Style="background: rgba(0,0,0,0.3); border: 1px dashed #cf4024; height: 100%;">
                <MudText Typo="Typo.h6" Color="Color.Secondary" Class="mb-4" Style="font-family: 'Press Start 2P'; font-size: 0.8rem;">
                    /// DIRECTORY
                </MudText>
                <MudText Typo="Typo.body2" Class="mb-6" Style="font-family: 'Rajdhani'; color: #888;">
                    Other garages, labs, and studios on the open web.
                </MudText>

                <!-- 88x31 Button Wall -->
                <div class="button-wall mb-8">
                    
                    <a href="https://godotengine.org" target="_blank">
                        <img src="/images/buttons/godot.png" style="background:#333;" />
                    </a>
                    <a href="https://www.aseprite.com/" target="_blank">
                        <img src="/images/buttons/aseprite.png" style="background:#333;" />
                    </a>
                    <a href="https://www.bostonindies.com/" target="_blank">
                        <img src="/images/buttons/boston_indies.png" style="background:#FFF;" />
                    </a>
                    <a href="https://www.snoozykazoo.com/" target="_blank">
                        <img src="/images/buttons/snoozy-kazoo.png" style="background:#333;" />
                    </a>
                    <a href="https://www.bostongamedev.com/" target="_blank">
                        <img src="/images/buttons/BGD.webp" style="background:#333;" />
                    </a>
                    <a href="https://www.studiobluejay.com/" target="_blank">
                        <img src="/images/buttons/studio_blue_jay.png" style="background:#FFF;" />
                    </a>
                    <a href="https://www.skymap.com/" target="_blank">
                        <img src="/images/buttons/Skymap_Logo.webp" style="background:#333;" />
                    </a>
                    <a href="https://www.weloveeverygame.com/" target="_blank">
                        <img src="/images/buttons/we_love_every_game.png" style="background:#333;" />
                    </a>
                    <MudDivider Class="mb-6" />
                    <a href="https://www.spacecapsulegames.com/" target="_blank">
                        <img src="/images/buttons/spacecapsulegames.png" style="background:#333; width:60px;" />
                    </a>
                    <a href="https://www.popcannibal.com/" target="_blank">
                        <img src="/images/buttons/popcannibal.png" style="background:#333; width:60px;" />
                    </a>
                     <a href="https://www.dejobaangames.com/" target="_blank">
                        <img src="/images/buttons/dejobaan_games.webp" style="background:#333; width:60px;" />
                    </a>
                    <a href="https://www.freezebeam.com/" target="_blank">
                        <img src="/images/buttons/freezebeam.png" style="background:#333; width:60px;" />
                    </a>
                    
                    
                </div>

                <MudDivider Class="mb-6" />

                <!-- Share Your Button -->
                <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="mb-2" Style="font-family: 'Press Start 2P'; font-size: 0.6rem;">
                    LINK TO GETTE GARAGE
                </MudText>
                <div class="button-wall mb-8">
                    <img src="/images/GetteGarage_button.png" alt="Gette Garage Button" />
                    <code style="background: #050510; color: #00ff00; padding: 8px; font-size: 0.6rem; border: 1px solid #333; overflow-x: auto;">
                        &lt;a href="https://gettegarage.com"&gt;&lt;img src="https://gettegarage.com/images/GetteGarage_button.png" alt="Gette Garage"&gt;&lt;/a&gt;
                    </code>
                </div>
            </MudPaper>
        </MudItem>

        <!-- RIGHT COLUMN: The Guestbook -->
        <MudItem xs="12" md="7">
            <!-- Giscus Component -->
            <CommentsSection Topic="GUESTBOOK" />
        </MudItem>
    </MudGrid>

</MudContainer>

<style>
    .button-wall {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
    }
    .button-wall img {
        width: 88px;
        image-rendering: pixelated;
        border: 1px solid #333;
        transition: transform 0.1s;
    }
    .button-wall img:hover {
        transform: scale(1.1);
        border-color: #f6a91f;
    }
</style>